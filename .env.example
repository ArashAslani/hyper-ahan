# Copy to `.env.local` for local overrides (file is gitignored).
# When empty / unset, the Next.js rewrite in `next.config.ts` proxies `/api/*` to the backend.

# Public API origin (browser-visible). Prefer leaving unset in local dev and using the rewrite.
NEXT_PUBLIC_API_BASE_URL=

# Optional: direct backend origin for server-side fetches (defaults to
# http://localhost:5062 in src/lib/api-client.ts if unset).
# API_BASE_URL=http://localhost:5062

# Public site origin, used for canonical/OG/JSON-LD absolute URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
