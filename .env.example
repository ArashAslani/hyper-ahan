# Copy to `.env.local` for local overrides (file is gitignored).

# Backend API origin used by the browser and (optionally) the server.
# Local default: http://localhost:5062
NEXT_PUBLIC_API_BASE_URL=http://localhost:5062

# Optional: server-only override (SSR/build). Defaults to NEXT_PUBLIC_API_BASE_URL
# or http://localhost:5062 when unset/empty.
API_BASE_URL=http://localhost:5062

# Public site origin, used for canonical/OG/JSON-LD absolute URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
